{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"postinstall": "node scripts/ensure-better-sqlite3.mjs",
		"predev": "node scripts/ensure-better-sqlite3.mjs",
		"prebuild": "node scripts/ensure-better-sqlite3.mjs",
		"prepreview": "node scripts/ensure-better-sqlite3.mjs",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"migrate-fs": "node scripts/migrate-to-fs.mjs",
		"rebuild-cache": "node scripts/rebuild-cache.mjs"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/better-sqlite3": "^7.6.13",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.98",
		"better-sqlite3": "^12.8.0",
		"katex": "^0.16.44",
		"marked": "^17.0.5",
		"marked-katex-extension": "^5.1.7",
		"pdfjs-dist": "^4.10.38",
		"zod": "^4.3.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3"
		]
	}
}
